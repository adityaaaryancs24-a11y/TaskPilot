# ─── LLM Configuration ─────────────────────────────────────────────────────
# Primary LLM (Gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Fallback LLM (xAI/Grok)
LLM_API_KEY=
LLM_MODEL=grok-3-mini
LLM_BASE_URL=https://api.x.ai/v1
XAI_API_KEY=

# ─── Connector Credentials ─────────────────────────────────────────────────
# Jira
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# GitHub
GITHUB_TOKEN=
GITHUB_REPO_OWNER=taskpilot-ai
GITHUB_REPO_NAME=backend

# Outlook (Microsoft Graph)
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=
OUTLOOK_USER_EMAIL=

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ServiceNow
SERVICENOW_INSTANCE=
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=

# ─── Database ──────────────────────────────────────────────────────────────
# Set DATABASE_URL for PostgreSQL; leave empty to use SQLite
DATABASE_URL=postgresql+asyncpg://taskpilot:taskpilot@localhost:5432/taskpilot
# DATABASE_URL=sqlite+aiosqlite:///db/taskpilot.db

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Celery ────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Security ──────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
API_RATE_LIMIT_PER_MINUTE=60

# ─── Embedding Model ───────────────────────────────────────────────────────
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_CACHE_ENABLED=true

# ─── Monitoring ────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
OTEL_SERVICE_NAME=taskpilot-ai
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or text

# ─── Pipeline ──────────────────────────────────────────────────────────────
EXTRACTION_CONFIDENCE_THRESHOLD=0.50
PIPELINE_SYNC_INTERVAL_MINUTES=15
MAX_CONCURRENT_SYNCS=3
